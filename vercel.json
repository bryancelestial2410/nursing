{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/auth(.*)", "dest": "server.js" },
    { "src": "/tools(.*)", "dest": "server.js" },
    { "src": "/reservations(.*)", "dest": "server.js" },
    { "src": "/", "dest": "frontend/register.html" },
    { "src": "/(.*\\.(html|css|js|png|jpg|ico))", "dest": "frontend/$1" },
    { "src": "/(.*)", "dest": "frontend/$1.html" }
  ]
}