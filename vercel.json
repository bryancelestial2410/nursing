{
  "version": 2,
  "builds": [
    {
      "src": "my-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/auth(.*)",
      "dest": "my-backend/server.js"
    },
    {
      "src": "/tools(.*)",
      "dest": "my-backend/server.js"
    },
    {
      "src": "/reservations(.*)",
      "dest": "my-backend/server.js"
    },
    {
      "src": "/",
      "dest": "frontend/register.html"
    },
    {
      "src": "/(.*\\.(html|css|js|png|jpg|ico))",
      "dest": "frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1.html"
    }
  ]
}